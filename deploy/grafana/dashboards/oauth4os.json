{
  "dashboard": {
    "title": "oauth4os",
    "uid": "oauth4os",
    "panels": [
      {
        "title": "Requests / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [{"expr": "rate(oauth4os_requests_total[5m])", "legendFormat": "req/s"}]
      },
      {
        "title": "Active Requests",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [{"expr": "oauth4os_requests_active"}]
      },
      {
        "title": "Uptime",
        "type": "stat",
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
        "targets": [{"expr": "oauth4os_uptime_seconds"}],
        "fieldConfig": {"defaults": {"unit": "s"}}
      },
      {
        "title": "Auth Success vs Failure",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {"expr": "rate(oauth4os_auth_success[5m])", "legendFormat": "success/s"},
          {"expr": "rate(oauth4os_auth_failed[5m])", "legendFormat": "failed/s"}
        ]
      },
      {
        "title": "Error Rate %",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [{"expr": "rate(oauth4os_requests_failed[5m]) / rate(oauth4os_requests_total[5m]) * 100", "legendFormat": "error %"}],
        "fieldConfig": {"defaults": {"unit": "percent"}}
      },
      {
        "title": "Cedar Denials / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
        "targets": [{"expr": "rate(oauth4os_cedar_denied[5m])", "legendFormat": "denied/s"}]
      },
      {
        "title": "Rate Limited / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16},
        "targets": [{"expr": "rate(oauth4os_rate_limited[5m])", "legendFormat": "limited/s"}]
      },
      {
        "title": "Upstream Errors / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
        "targets": [{"expr": "rate(oauth4os_upstream_errors[5m])", "legendFormat": "errors/s"}]
      },
      {
        "title": "Cache Hit Rate %",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
        "targets": [{"expr": "rate(oauth4os_cache_hits[5m]) / (rate(oauth4os_cache_hits[5m]) + rate(oauth4os_cache_misses[5m])) * 100", "legendFormat": "hit %"}],
        "fieldConfig": {"defaults": {"unit": "percent"}}
      },
      {
        "title": "Cache Hits vs Misses / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
        "targets": [
          {"expr": "rate(oauth4os_cache_hits[5m])", "legendFormat": "hits/s"},
          {"expr": "rate(oauth4os_cache_misses[5m])", "legendFormat": "misses/s"}
        ]
      },
      {
        "title": "Circuit Breaker Opens / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 32},
        "targets": [{"expr": "rate(oauth4os_circuit_opens[5m])", "legendFormat": "opens/s"}]
      },
      {
        "title": "Load Shedding — Inflight",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 32},
        "targets": [{"expr": "oauth4os_loadshed_inflight"}]
      },
      {
        "title": "Load Shed Rejections / sec",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 32},
        "targets": [{"expr": "rate(oauth4os_loadshed_total[5m])", "legendFormat": "shed/s"}]
      },
      {
        "title": "Upstream Latency (ms)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "targets": [{"expr": "oauth4os_upstream_latency_ms", "legendFormat": "latency ms"}],
        "fieldConfig": {"defaults": {"unit": "ms"}}
      },
      {
        "title": "Upstream Healthy",
        "type": "stat",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "targets": [{"expr": "oauth4os_upstream_healthy"}],
        "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}}
      },
      {
        "type": "timeseries",
        "title": "Request Latency P50 / P95 / P99",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
        "targets": [
          {"expr": "histogram_quantile(0.50, rate(oauth4os_request_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
          {"expr": "histogram_quantile(0.95, rate(oauth4os_request_duration_seconds_bucket[5m]))", "legendFormat": "p95"},
          {"expr": "histogram_quantile(0.99, rate(oauth4os_request_duration_seconds_bucket[5m]))", "legendFormat": "p99"}
        ],
        "fieldConfig": {"defaults": {"unit": "s"}}
      },
      {
        "type": "timeseries",
        "title": "Request Latency by Endpoint (P95)",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40},
        "targets": [
          {"expr": "histogram_quantile(0.95, rate(oauth4os_request_duration_seconds_bucket{path!=\"\"}[5m]))", "legendFormat": "{{path}}"}
        ],
        "fieldConfig": {"defaults": {"unit": "s"}}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
