#!/usr/bin/env bash
# oauth4os-demo — interactive CLI demo using curl + jq
# Install: curl -sL https://f5cmk2hxwx.us-west-2.awsapprunner.com/install.sh | bash
set -euo pipefail

PROXY="${OAUTH4OS_URL:-https://f5cmk2hxwx.us-west-2.awsapprunner.com}"
TOKEN_FILE="${HOME}/.oauth4os-demo-token"
CLIENT_ID="${OAUTH4OS_CLIENT_ID:-demo-agent}"
CLIENT_SECRET="${OAUTH4OS_CLIENT_SECRET:-demo-secret}"
SCOPE="${OAUTH4OS_SCOPE:-read:logs-*}"

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'; BOLD='\033[1m'; NC='\033[0m'

usage() {
  cat <<EOF
${BOLD}oauth4os-demo${NC} — OAuth 2.0 proxy for OpenSearch demo CLI

${BOLD}USAGE:${NC}
  oauth4os-demo <command> [args]

${BOLD}COMMANDS:${NC}
  login              Authenticate and cache token
  logout             Clear cached token
  search <query>     Search logs (KQL syntax: level:ERROR, service:payment)
  services           List available services
  tail [service]     Show latest 20 log entries (optionally filter by service)
  stats              Show request stats from analytics
  health             Check proxy health
  token              Show current token info
  whoami             Show token claims

${BOLD}EXAMPLES:${NC}
  oauth4os-demo login
  oauth4os-demo search 'level:ERROR'
  oauth4os-demo search 'service:payment AND level:WARN'
  oauth4os-demo tail auth
  oauth4os-demo services
  oauth4os-demo stats

${BOLD}ENVIRONMENT:${NC}
  OAUTH4OS_URL          Proxy URL (default: ${PROXY})
  OAUTH4OS_CLIENT_ID    Client ID (default: demo-agent)
  OAUTH4OS_SCOPE        Scope (default: read:logs-*)
EOF
}

check_deps() {
  for cmd in curl jq; do
    command -v "$cmd" >/dev/null 2>&1 || { echo -e "${RED}Error: $cmd is required. Install it first.${NC}"; exit 1; }
  done
}

get_token() {
  if [ -f "$TOKEN_FILE" ]; then
    local exp
    exp=$(jq -r '.expires_at // 0' "$TOKEN_FILE" 2>/dev/null)
    if [ "$(date +%s)" -lt "$exp" ] 2>/dev/null; then
      jq -r '.access_token' "$TOKEN_FILE"
      return 0
    fi
  fi
  return 1
}

require_token() {
  local tok
  tok=$(get_token 2>/dev/null) || { echo -e "${RED}Not logged in. Run: oauth4os-demo login${NC}"; exit 1; }
  echo "$tok"
}

cmd_login() {
  echo -e "${CYAN}Authenticating with oauth4os...${NC}"
  local resp
  resp=$(curl -sf -X POST "${PROXY}/oauth/token" \
    -d "grant_type=client_credentials" \
    -d "client_id=${CLIENT_ID}" \
    -d "client_secret=${CLIENT_SECRET}" \
    -d "scope=${SCOPE}" 2>&1) || { echo -e "${RED}Login failed. Is the proxy running at ${PROXY}?${NC}"; exit 1; }

  local token expires_in
  token=$(echo "$resp" | jq -r '.access_token // empty')
  expires_in=$(echo "$resp" | jq -r '.expires_in // 3600')

  if [ -z "$token" ]; then
    echo -e "${RED}Login failed: $(echo "$resp" | jq -r '.error // "unknown error"')${NC}"
    exit 1
  fi

  local expires_at
  expires_at=$(( $(date +%s) + expires_in ))
  jq -n --arg t "$token" --arg e "$expires_at" --arg s "$SCOPE" \
    '{access_token:$t, expires_at:($e|tonumber), scope:$s}' > "$TOKEN_FILE"
  chmod 600 "$TOKEN_FILE"

  echo -e "${GREEN}✓ Logged in${NC} as ${BOLD}${CLIENT_ID}${NC}"
  echo -e "  Scope: ${CYAN}${SCOPE}${NC}"
  echo -e "  Expires in: ${expires_in}s"
}

cmd_logout() {
  rm -f "$TOKEN_FILE"
  echo -e "${GREEN}✓ Logged out${NC}"
}

cmd_search() {
  local tok query="$*"
  tok=$(require_token)
  [ -z "$query" ] && { echo -e "${YELLOW}Usage: oauth4os-demo search <query>${NC}"; exit 1; }

  echo -e "${CYAN}Searching:${NC} ${query}"
  local body
  body=$(jq -n --arg q "$query" '{query:{query_string:{query:$q}},size:20,sort:[{"@timestamp":"desc"}]}')

  local resp
  resp=$(curl -sf -H "Authorization: Bearer ${tok}" \
    -H "Content-Type: application/json" \
    "${PROXY}/logs-*/_search" -d "$body" 2>&1) || { echo -e "${RED}Search failed${NC}"; exit 1; }

  local total
  total=$(echo "$resp" | jq '.hits.total.value // (.hits.total // 0)')
  echo -e "${GREEN}${total} hits${NC}\n"

  echo "$resp" | jq -r '.hits.hits[]._source | "\(.["@timestamp"] // .timestamp // "—") [\(.level // "INFO")] \(.service // "unknown"): \(.message // .msg // "")"' 2>/dev/null | head -20 | while IFS= read -r line; do
    if echo "$line" | grep -qi 'error\|fatal'; then
      echo -e "${RED}${line}${NC}"
    elif echo "$line" | grep -qi 'warn'; then
      echo -e "${YELLOW}${line}${NC}"
    else
      echo "$line"
    fi
  done
}

cmd_services() {
  local tok
  tok=$(require_token)
  echo -e "${CYAN}Services with log data:${NC}\n"

  local body='{"size":0,"aggs":{"services":{"terms":{"field":"service.keyword","size":50}}}}'
  local resp
  resp=$(curl -sf -H "Authorization: Bearer ${tok}" \
    -H "Content-Type: application/json" \
    "${PROXY}/logs-*/_search" -d "$body" 2>&1) || { echo -e "${RED}Query failed${NC}"; exit 1; }

  echo "$resp" | jq -r '.aggregations.services.buckets[] | "  \(.key) (\(.doc_count) logs)"' 2>/dev/null || echo "  (no aggregation data)"
}

cmd_tail() {
  local tok service="${1:-}"
  tok=$(require_token)

  local body
  if [ -n "$service" ]; then
    echo -e "${CYAN}Latest logs for ${BOLD}${service}${NC}:"
    body=$(jq -n --arg s "$service" '{query:{term:{"service.keyword":$s}},size:20,sort:[{"@timestamp":"desc"}]}')
  else
    echo -e "${CYAN}Latest logs:${NC}"
    body='{"query":{"match_all":{}},"size":20,"sort":[{"@timestamp":"desc"}]}'
  fi

  local resp
  resp=$(curl -sf -H "Authorization: Bearer ${tok}" \
    -H "Content-Type: application/json" \
    "${PROXY}/logs-*/_search" -d "$body" 2>&1) || { echo -e "${RED}Query failed${NC}"; exit 1; }

  echo ""
  echo "$resp" | jq -r '.hits.hits[]._source | "\(.["@timestamp"] // .timestamp // "—") [\(.level // "INFO")] \(.service // "?"): \(.message // .msg // "")"' 2>/dev/null | while IFS= read -r line; do
    if echo "$line" | grep -qi 'error\|fatal'; then
      echo -e "${RED}${line}${NC}"
    elif echo "$line" | grep -qi 'warn'; then
      echo -e "${YELLOW}${line}${NC}"
    else
      echo "$line"
    fi
  done
}

cmd_stats() {
  echo -e "${CYAN}Analytics:${NC}\n"
  local resp
  resp=$(curl -sf "${PROXY}/admin/analytics" 2>&1) || { echo -e "${RED}Failed to fetch analytics${NC}"; exit 1; }

  echo -e "${BOLD}Top Clients:${NC}"
  echo "$resp" | jq -r '.top_clients[:5][] | "  \(.client_id): \(.requests) requests (last seen: \(.last_seen))"' 2>/dev/null

  echo -e "\n${BOLD}Scope Usage:${NC}"
  echo "$resp" | jq -r '.scope_distribution[:5][] | "  \(.name): \(.count)"' 2>/dev/null

  echo -e "\n${BOLD}Top Indices:${NC}"
  echo "$resp" | jq -r '.top_indices[:5][] | "  \(.name): \(.count) requests"' 2>/dev/null
}

cmd_health() {
  local resp
  resp=$(curl -sf "${PROXY}/health" 2>&1) || { echo -e "${RED}Proxy unreachable at ${PROXY}${NC}"; exit 1; }
  echo -e "${GREEN}✓ Proxy healthy${NC}"
  echo "$resp" | jq . 2>/dev/null || echo "$resp"
}

cmd_token() {
  if get_token >/dev/null 2>&1; then
    local exp
    exp=$(jq -r '.expires_at' "$TOKEN_FILE")
    local remaining=$(( exp - $(date +%s) ))
    echo -e "${GREEN}✓ Token cached${NC}"
    echo -e "  Scope: $(jq -r '.scope' "$TOKEN_FILE")"
    echo -e "  Expires in: ${remaining}s"
  else
    echo -e "${YELLOW}No valid token. Run: oauth4os-demo login${NC}"
  fi
}

cmd_whoami() {
  local tok
  tok=$(require_token)
  # Decode JWT payload (middle segment)
  local payload
  payload=$(echo "$tok" | cut -d. -f2 | tr '_-' '/+' | base64 -d 2>/dev/null || echo '{}')
  echo -e "${CYAN}Token claims:${NC}"
  echo "$payload" | jq . 2>/dev/null || echo "$payload"
}

# --- main ---
check_deps
case "${1:-}" in
  login)    cmd_login ;;
  logout)   cmd_logout ;;
  search)   shift; cmd_search "$@" ;;
  services) cmd_services ;;
  tail)     shift; cmd_tail "${1:-}" ;;
  stats)    cmd_stats ;;
  health)   cmd_health ;;
  token)    cmd_token ;;
  whoami)   cmd_whoami ;;
  help|-h|--help) usage ;;
  *)        usage ;;
esac
